# Client-visible configuration only. Do not put secrets in Flutter assets,
# dart-define values, or any file shipped with the app.
#
# Preferred:
#   flutter run --dart-define=API_BASE_URL=https://api.example.com
#
# Products may also add their own optional .env asset, but .env stays ignored
# in this base repository. No trailing slash.
API_BASE_URL=https://example.com
